# Butane file for creating ignition definition for FCOS based k3s node
#
# TODO: Remove this when k3s-autoscaler supports using k3s-vm.butane.j2
#
---
variant: fcos
version: 1.4.0
{% if fcos_kernel_arguments | d([]) %}
kernel_arguments:
  should_exist:
{% for karg in fcos_kernel_arguments %}
    - {{ karg }}
{% endfor %}
{% endif %}
systemd:
  units:
{% if fcos_upgrade_on_first_boot | d(false) | bool %}
    - name: oneshot-system-upgrade.service
      enabled: true
      contents: |
        [Unit]
        After=network-online.target
        Wants=network-online.target
        Before=systemd-user-sessions.service
        OnFailure=emergency.target
        OnFailureJobMode=replace-irreversibly
        ConditionPathExists=!/var/lib/system-upgraded

        [Service]
        RemainAfterExit=yes
        Type=oneshot
        ExecStart=/usr/bin/rpm-ostree upgrade
        ExecStartPost=/usr/bin/touch /var/lib/system-upgraded
        ExecStartPost=/usr/bin/systemctl --no-block reboot

        [Install]
        WantedBy=multi-user.target
{% endif %}

{% if fcos_kernel_version | d('') %}
    # Stage a newer kernel from a Fedora repo mirror
    - name: oneshot-kernel-upgrade.service
      enabled: true
      contents: |
        [Unit]
{% if fcos_upgrade_on_first_boot | d(false) | bool %}
        After=network-online.target oneshot-system-upgrade.service
{% else %}
        After=network-online.target
{% endif %}
        Wants=network-online.target
        Before=oneshot-k3s-installer.service
        Before=systemd-user-sessions.service
        OnFailure=emergency.target
        OnFailureJobMode=replace-irreversibly
        ConditionPathExists=!/var/lib/kernel-upgraded

        [Service]
        RemainAfterExit=yes
        Type=oneshot
        ExecStart=/usr/local/sbin/run-kernel-upgrade.sh
        ExecStartPost=/usr/bin/touch /var/lib/kernel-upgraded

        [Install]
        WantedBy=multi-user.target
{% endif %}

    - name: oneshot-k3s-installer.service
      enabled: true
      contents: |
        [Unit]
{% if fcos_kernel_version | d('') %}
        After=network-online.target oneshot-kernel-upgrade.service
{% elif fcos_upgrade_on_first_boot | d(false) | bool %}
        After=oneshot-system-upgrade.service
{% else %}
        After=network-online.target
{% endif %}
        Wants=network-online.target
        Before=systemd-user-sessions.service
        OnFailure=emergency.target
        OnFailureJobMode=replace-irreversibly
        ConditionPathExists=!/var/lib/k3s-installed

        [Service]
        RemainAfterExit=yes
        Type=oneshot
        ExecStart=/usr/local/sbin/run-k3s-installer.sh
        ExecStartPost=/usr/bin/touch /var/lib/k3s-installed
        ExecStartPost=/usr/bin/systemctl --no-block reboot

        [Install]
        WantedBy=multi-user.target

    # disable zincati
    - name: zincati.service
      mask: true

storage:
  disks:
  - device: /dev/vdb
    wipe_table: true
    partitions:
    - number: 1
      label: var
      size_mib: 0
      resize: true
  filesystems:
    - path: /var
      device: /dev/disk/by-partlabel/var
      format: xfs
      with_mount_unit: true

  files:
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: {{ server_name }}

    - path: /usr/local/sbin/run-k3s-installer.sh
      mode: 0755
      contents:
        inline: |
          #!/usr/bin/env sh
          main() {
            export INSTALL_K3S_VERSION="{{ k3s_version }}"
            export K3S_URL="https://{{ master_vm_ip }}:6443"
            export K3S_TOKEN="{{ k3s_node_token }}"
            export K3S_KUBECONFIG_MODE="644"
            export INSTALL_K3S_CHANNEL="{{ k3s_channel|d('stable') }}"
            export INSTALL_K3S_EXEC="--node-label role=user --node-taint role=user:NoSchedule {{ extra_k3s_args|d('') }}"
            curl -sfL {{ k3s_installer_url|d("https://get.k3s.io") }} | sh -
            return 0
          }
          main

{% if fcos_kernel_version | d('') %}
    - path: /usr/local/sbin/run-kernel-upgrade.sh
      mode: 0755
      contents:
        inline: |
          #!/usr/bin/env sh
          # Replace the FCOS base kernel with a pinned build from a Fedora mirror (HTTPS-trusted).
          set -e
          main() {
            arch="{{ fcos_kernel_arch | d('x86_64') }}"
            ver="{{ fcos_kernel_version }}"
            baseurl="{{ fcos_kernel_base_url }}"
            workdir=$(mktemp -d /var/tmp/kernel-upgrade.XXXXXX)
            trap 'rm -rf "$workdir"' EXIT
            for pkg in {{ fcos_kernel_packages | d(['kernel', 'kernel-core', 'kernel-modules', 'kernel-modules-core']) | join(' ') }}; do
              rpm="${pkg}-${ver}.${arch}.rpm"
              echo "downloading ${baseurl}${rpm}"
              curl --fail --location --retry 5 --retry-delay 2 -o "${workdir}/${rpm}" "${baseurl}${rpm}"
            done
            echo "replacing kernel with ${ver}"
            rpm-ostree override replace "${workdir}"/*.rpm
            return 0
          }
          main
{% endif %}

    - path: /etc/systemd/network/50-flannel.link
      mode: 0644
      contents:
        inline: |
          [Match]
          OriginalName=flannel*
          [Link]
          MACAddressPolicy=none

{% if private_registry_enabled | d(false) | bool %}
    - path: /etc/rancher/k3s/registries.yaml
      mode: 0644
      contents:
        inline: |
          mirrors:
            "private-registry:5000":
              endpoint:
                - "http://{{ master_vm_ip }}:5000"
{% endif %}

    # only do manual updates
    - path: /etc/zincati/config.d/90-disable-auto-updates.toml
      mode: 0644
      contents:
        inline: |
          [updates]
          enabled = false

    # disable user namespaces by default to mitigate related vulnerabilities
    - path: /etc/sysctl.d/99-disable-user-namespaces.conf
      mode: 0644
      contents:
        inline: |
          user.max_user_namespaces = {{ fcos_max_user_namespaces|d(0) }}

{% if fcos_max_user_namespaces|d(0) == 0 %}
    # fix irqbalance when user namespaces are disabled. Adapted from https://access.redhat.com/solutions/7097092
    - path: /etc/systemd/system/irqbalance.service.d/override.conf
      mode: 0644
      contents:
        inline: |
          [Service]
          PrivateUsers=false
{% endif %}
